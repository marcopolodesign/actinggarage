# Resend + webhook configuration (server-side)
RESEND_API_KEY=your_resend_api_key_here
# Must be a verified sender/domain in Resend
RESEND_FROM="The Acting Garage <no-reply@theactinggarage.com>"

# Secure Supabase Webhooks -> Vercel API calls
EMAIL_WEBHOOK_SECRET=choose_a_long_random_secret

# Supabase admin (server-side) for reading preferences + course/student lookup
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Public base URL used to generate unsubscribe links
PUBLIC_BASE_URL=https://theactinggarage.com
